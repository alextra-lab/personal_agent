# Personal Agent Configuration Template
# Copy this file to .env and customize for your environment.
# See: docs/architecture_decisions/ADR-0007-unified-configuration-management.md
#
# ─────────────────────────────────────────────────────────────────────────────
# VPS / PRODUCTION DEPLOYMENT
# Create /opt/seshat/.env on the VPS with chmod 600 and set these values:
#
#   APP_ENV=production
#
#   # Docker Compose passwords (referenced by docker-compose.cloud.yml)
#   POSTGRES_PASSWORD=<strong-random-password>
#   NEO4J_PASSWORD=<strong-random-password>
#
#   # Cloud LLM API keys (required for cloud execution path)
#   AGENT_ANTHROPIC_API_KEY=sk-ant-...
#   AGENT_OPENAI_API_KEY=sk-...
#   AGENT_PERPLEXITY_API_KEY=pplx-...
#
#   # Embedding service (llama.cpp on VPS — internal Docker network)
#   # Override the default localhost:8503 from models.yaml
#   AGENT_EMBEDDING_ENDPOINT=http://embeddings:8503/v1
#   AGENT_RERANKER_ENDPOINT=http://embeddings:8504/v1
#
#   # Event bus (enabled in production)
#   AGENT_EVENT_BUS_ENABLED=true
#   AGENT_ENABLE_MEMORY_GRAPH=true
#
#   # Cloudflare Tunnel — WARP private network (get token from Zero Trust → Tunnels)
#   CLOUDFLARE_TUNNEL_TOKEN=eyJ...
#
#   # Cloudflare Access service token — Mac SLM tunnel (slm.frenchforet.com)
#   # Generated by: cd infrastructure/terraform-cloudflare-mac && terraform apply
#   # See docs/superpowers/specs/2026-04-17-mac-slm-tunnel-design.md
#   CF_ACCESS_CLIENT_ID=<from terraform output cf_access_client_id>
#   CF_ACCESS_CLIENT_SECRET=<from terraform output cf_access_client_secret>
#
#   # Gateway Bearer tokens — must match config/gateway_access.yaml entries
#   # Generate with: openssl rand -hex 32
#   GATEWAY_TOKEN_PWA=<openssl rand -hex 32>
#   GATEWAY_TOKEN_EXTERNAL_AGENT=<openssl rand -hex 32>
#   AGENT_GATEWAY_AUTH_ENABLED=true
#
# Generate strong passwords/tokens:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Current environment: development, staging, production, test
# Default: development
# APP_ENV=development

# Debug mode (enables verbose logging and additional checks)
# Default: false
# APP_DEBUG=false

# =============================================================================
# APPLICATION
# =============================================================================
# Project name (informational)
# Default: Personal Local AI Collaborator
# PROJECT_NAME=Personal Local AI Collaborator

# Application version (informational)
# Default: 0.1.0
# VERSION=0.1.0

# =============================================================================
# TELEMETRY & LOGGING
# =============================================================================
# Log directory path (relative to project root or absolute)
# Default: telemetry/logs
# LOG_DIR=telemetry/logs

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# APP_LOG_LEVEL=INFO

# Log format: json (structured) or console (human-readable)
# Default: json
# APP_LOG_FORMAT=json

# =============================================================================
# LLM CLIENT
# =============================================================================
# Base URL for LLM API (OpenAI-compatible endpoint)
# Default: http://localhost:1234/v1 (LM Studio)
# Common alternatives:
#   - LM Studio: http://localhost:1234/v1
#   - Ollama: http://localhost:11434/v1
#   - OpenAI: https://api.openai.com/v1
# LLM_BASE_URL=http://localhost:1234/v1

# LLM request timeout in seconds (1-600)
# Default: 120
# LLM_TIMEOUT_SECONDS=120

# Maximum retry attempts for failed LLM requests (0+)
# Default: 3
# LLM_MAX_RETRIES=3

# Optional suffix token to discourage verbose reasoning (model-specific)
# Works with some models (e.g., Qwen3) to reduce latency
# Default: /no_think
# LLM_NO_THINK_SUFFIX=/no_think

# Append no-think suffix to tool prompts (reduces latency)
# Default: true
# LLM_APPEND_NO_THINK_TO_TOOL_PROMPTS=true

# =============================================================================
# ORCHESTRATOR
# =============================================================================
# Maximum concurrent tasks (0+)
# Default: 5
# ORCHESTRATOR_MAX_CONCURRENT_TASKS=5

# Task timeout in seconds (1+)
# Default: 300
# ORCHESTRATOR_TASK_TIMEOUT_SECONDS=300

# Maximum tool execution iterations per user request (prevents loops)
# Default: 3
# ORCHESTRATOR_MAX_TOOL_ITERATIONS=3

# Maximum times the same tool call signature can repeat per request
# Default: 1
# ORCHESTRATOR_MAX_REPEATED_TOOL_CALLS=1

# =============================================================================
# ROUTING (ORCHESTRATOR)
# =============================================================================
# Routing policy: heuristic_then_llm, heuristic_only, or llm_only
# Default: heuristic_then_llm
# AGENT_ROUTING_POLICY=heuristic_then_llm

# Only call LLM router when heuristic confidence is below this (0.0-1.0)
# Default: 0.85
# AGENT_ROUTING_HEURISTIC_THRESHOLD=0.85

# Timeout for router LLM call in seconds; on timeout fall back to heuristic
# Default: 6.0
# AGENT_ROUTER_TIMEOUT_SECONDS=6.0

# Role used for routing: ROUTER (dedicated small model) or STANDARD (single-model mode)
# Default: ROUTER
# AGENT_ROUTER_ROLE=ROUTER

# If false, map REASONING to STANDARD (single-model mode)
# Default: true
# AGENT_ENABLE_REASONING_ROLE=true

# =============================================================================
# CONVERSATION (CONTEXT WINDOW)
# =============================================================================
# Maximum historical session messages to hydrate into orchestrator
# Default: 10
# AGENT_CONVERSATION_MAX_HISTORY_MESSAGES=10

# Maximum context token budget for conversation messages before each LLM call
# Default: 2048
# AGENT_CONTEXT_WINDOW_MAX_TOKENS=2048

# Context window strategy. Supported: truncate
# Default: truncate
# AGENT_CONVERSATION_CONTEXT_STRATEGY=truncate

# Enable async LLM-based compression of evicted conversation turns (ADR-0038).
# When true, evicted turns are summarized by the compressor model (config/models.yaml)
# and injected as a system message on the next turn.
# Default: true
# AGENT_CONTEXT_COMPRESSION_ENABLED=true

# Fire compression when estimated tokens exceed this fraction of context_window_max_tokens.
# Default: 0.65
# AGENT_CONTEXT_COMPRESSION_THRESHOLD_RATIO=0.65

# =============================================================================
# BRAINSTEM (MODE MANAGEMENT)
# =============================================================================
# Sensor polling interval in seconds (>0)
# Default: 5.0
# BRAINSTEM_SENSOR_POLL_INTERVAL_SECONDS=5.0

# =============================================================================
# REQUEST MONITORING (ADR-0012)
# =============================================================================
# Enable automatic request-scoped metrics monitoring
# Default: true
# REQUEST_MONITORING_ENABLED=true

# Request monitoring polling interval in seconds (>0)
# Default: 5.0
# REQUEST_MONITORING_INTERVAL_SECONDS=5.0

# Include GPU metrics in request monitoring (Apple Silicon: powermetrics)
# Default: true
# REQUEST_MONITORING_INCLUDE_GPU=true

# =============================================================================
# MCP GATEWAY (ADR-0011)
# =============================================================================
# Enable Docker MCP Gateway integration
# Default: false
# AGENT_MCP_GATEWAY_ENABLED=false

# Command to run Docker MCP Gateway
# Can be JSON array: ["docker", "mcp", "gateway", "run"]
# Or space-separated: "docker mcp gateway run"
# Default: ["docker", "mcp", "gateway", "run"]
# AGENT_MCP_GATEWAY_COMMAND=docker mcp gateway run

# Timeout for MCP operations in seconds (1-300)
# Default: 60
# AGENT_MCP_GATEWAY_TIMEOUT_SECONDS=60

# List of MCP server names to enable (comma-separated, empty = all)
# Default: [] (all servers enabled)
# Example: server1,server2,server3
# AGENT_MCP_GATEWAY_ENABLED_SERVERS=

# =============================================================================
# CONFIGURATION PATHS
# =============================================================================
# Path to governance config directory (relative to project root or absolute)
# Default: config/governance
# GOVERNANCE_CONFIG_PATH=config/governance

# Path to model config file (relative to project root or absolute)
# Default: config/models.yaml
# MODEL_CONFIG_PATH=config/models.yaml

# =============================================================================
# GATEWAY AUTHENTICATION
# =============================================================================
# Enables Bearer token validation on all gateway endpoints (ADR-0028).
# Set false locally (dev bundle has no token); set true on VPS only.
# Default: false
# AGENT_GATEWAY_AUTH_ENABLED=false
#
# Gateway tokens — VPS only (/opt/seshat/.env). DO NOT set locally.
# Values must match the hashed secrets in config/gateway_access.yaml.
# Generate with: openssl rand -hex 32
# GATEWAY_TOKEN_PWA=<secret>          — PWA bundle (read-only) + injected into seshat-gateway
# GATEWAY_TOKEN_EXTERNAL_AGENT=<secret> — external Claude Code / API agents + injected into seshat-gateway

# =============================================================================
# SECRETS (NEVER COMMIT THESE VALUES)
# =============================================================================
# API keys belong here. Model identity (which model to use) belongs in
# config/models.yaml — see ADR-0031.

# Anthropic API key — required when any role in config/models.yaml has provider: "anthropic"
# AGENT_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — required when any role in config/models.yaml has provider: "openai"
# AGENT_OPENAI_API_KEY=sk-...

# Perplexity AI API key — required for the perplexity_query native tool (ADR-0028 Phase 2)
# AGENT_PERPLEXITY_API_KEY=pplx-...

# Perplexity API base URL (override for proxy/testing)
# Default: https://api.perplexity.ai
# AGENT_PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Perplexity request timeout in seconds (10-300; research mode can be slow)
# Default: 90
# AGENT_PERPLEXITY_TIMEOUT_SECONDS=90

# =============================================================================
# EMBEDDING & RERANKER (Seshat Memory — ADR-0035)
# =============================================================================
# Model identity (which model, which endpoint) lives in config/models.yaml.
# Only runtime knobs belong here.

# Embedding vector dimensions (must match model output; 768 for Qwen3-Embedding-0.6B)
# Default: 768
# AGENT_EMBEDDING_DIMENSIONS=768

# Max items per embedding API call
# Default: 20
# AGENT_EMBEDDING_BATCH_SIZE=20

# Cosine similarity threshold for entity deduplication (0.0-1.0)
# Default: 0.85
# AGENT_DEDUP_SIMILARITY_THRESHOLD=0.85

# Enable cross-attention reranker in memory query pipeline
# Default: true
# AGENT_RERANKER_ENABLED=true

# Number of top candidates to re-score with reranker
# Default: 10
# AGENT_RERANKER_TOP_K=10

# =============================================================================
# PHASE 2.2: MEMORY & SECOND BRAIN
# =============================================================================
# Enable Neo4j memory graph
# Default: false
# AGENT_ENABLE_MEMORY_GRAPH=false

# Enable Second Brain background consolidation
# Default: false
# AGENT_ENABLE_SECOND_BRAIN=false

# Neo4j connection settings
# Default: bolt://localhost:7687
# AGENT_NEO4J_URI=bolt://localhost:7687
# AGENT_NEO4J_USER=neo4j
# AGENT_NEO4J_PASSWORD=neo4j_dev_password

# Process-to-model assignments and model parameters are configured in config/models.yaml:
#   entity_extraction_role, captains_log_role, insights_role  — which model each process uses
#   models.claude_sonnet.id, models.claude_sonnet.max_tokens  — cloud model identity
# No env vars needed for model selection.

# Weekly spending cap across all cloud LLM providers (USD)
# Default: 5.0
# AGENT_CLOUD_WEEKLY_BUDGET_USD=5.0

# Second Brain scheduling thresholds
# AGENT_SECOND_BRAIN_RESOURCE_GATING_ENABLED=true  # false = skip idle/CPU/memory checks (use when extraction is remote)
# AGENT_SECOND_BRAIN_IDLE_TIME_SECONDS=300         # 5 minutes idle
# AGENT_SECOND_BRAIN_CPU_THRESHOLD=50.0            # CPU usage < 50%
# AGENT_SECOND_BRAIN_MEMORY_THRESHOLD=70.0         # Memory usage < 70%
# AGENT_SECOND_BRAIN_CHECK_INTERVAL_SECONDS=60     # Check every minute
# AGENT_SECOND_BRAIN_MIN_INTERVAL_SECONDS=3600     # Min 1 hour between runs

# Data lifecycle and quality monitor (Phase 2.3)
# AGENT_DISK_USAGE_ALERT_PERCENT=80
# AGENT_DATA_LIFECYCLE_ENABLED=true
# AGENT_QUALITY_MONITOR_ENABLED=true
# AGENT_QUALITY_MONITOR_DAILY_RUN_HOUR_UTC=5
# AGENT_QUALITY_MONITOR_ANOMALY_WINDOW_DAYS=7

# =============================================================================
# INSIGHTS ENGINE (brainstem scheduler)
# =============================================================================
# Default: true
# AGENT_INSIGHTS_ENABLED=true
# Daily pattern analysis UTC hour (0-23)
# AGENT_INSIGHTS_DAILY_RUN_HOUR_UTC=6
# Weekly Captain's Log proposals: weekday 0=Monday .. 6=Sunday, UTC hour
# AGENT_INSIGHTS_WEEKLY_DAY=6
# AGENT_INSIGHTS_WEEKLY_RUN_HOUR_UTC=9

# =============================================================================
# CAPTAIN'S LOG → LINEAR FEEDBACK LOOP (ADR-0040)
# =============================================================================
# Requires: AGENT_MCP_GATEWAY_ENABLED=true, Linear authorized in Docker MCP, service running.
# Spec: docs/specs/SELF_IMPROVEMENT_FEEDBACK_LOOP_SPEC.md
# ADR: docs/architecture_decisions/ADR-0040-linear-async-feedback-channel.md
# Usage guide: docs/guides/LINEAR_FEEDBACK_LOOP.md
#
# Promotion now runs reactively via consolidation.completed events (Phase 3, ADR-0041).
# Daily Linear feedback poll uses AGENT_FEEDBACK_POLLING_HOUR_UTC.
#
# Enable/disable jobs
# Default: true
# AGENT_PROMOTION_PIPELINE_ENABLED=true
# AGENT_FEEDBACK_POLLING_ENABLED=true
# UTC hour (0-23) for daily feedback polling
# Default: 7
# AGENT_FEEDBACK_POLLING_HOUR_UTC=7
# Rejection suppression duration (days)
# Default: 30
# AGENT_FEEDBACK_SUPPRESSION_DAYS=30
# Max Deepen / Too Vague rounds per issue
# Default: 2
# AGENT_FEEDBACK_MAX_REEVALUATIONS=2
# Deferred revisit window (days; future hook)
# Default: 90
# AGENT_FEEDBACK_DEFER_REVISIT_DAYS=90
# Pause new promotions when non-archived Linear issues exceed this count
# Default: 200
# AGENT_ISSUE_BUDGET_THRESHOLD=200
# Max issues created per promotion run
# Default: 5
# AGENT_PROMOTION_INITIAL_CAP=5
# Linear team and project for promoted issues
# Default: FrenchForest / 2.3 Homeostasis & Feedback
# AGENT_LINEAR_TEAM_NAME=FrenchForest
# AGENT_LINEAR_PROMOTION_PROJECT=2.3 Homeostasis & Feedback

# =============================================================================
# PHASE 2.1: SERVICE FOUNDATION
# =============================================================================
# Service host and port
# AGENT_SERVICE_HOST=0.0.0.0
# AGENT_SERVICE_PORT=9000

# Base URL for CLI service client (used when running uv run agent)
# Default: http://localhost:9000
# AGENT_SERVICE_URL=http://localhost:9000

# PostgreSQL database URL
# AGENT_DATABASE_URL=postgresql+asyncpg://agent:agent_dev_password@localhost:5432/personal_agent
# AGENT_DATABASE_ECHO=false

# Elasticsearch for structured logging
# AGENT_ELASTICSEARCH_URL=http://localhost:9200
# AGENT_ELASTICSEARCH_INDEX_PREFIX=agent-logs

# Docker compose passwords (for docker-compose.yml)
# POSTGRES_PASSWORD=agent_dev_password
# NEO4J_PASSWORD=neo4j_dev_password

# =============================================================================
# EVENT BUS — Redis Streams (ADR-0041)
# =============================================================================
# Enable the Redis Streams event bus (default: False — polling continues).
# When True: Phase 1 (request.captured → consolidator), Phase 2 (request.completed →
# cg:es-indexer + cg:session-writer, durable /chat trace index + assistant DB append),
# and Phase 3 (consolidation.completed → cg:insights + cg:promotion;
# promotion.issue_created → cg:captain-log; feedback.received → cg:insights + cg:feedback;
# system.idle → cg:consolidator).  Scheduler no longer directly executes insights or
# promotion — those run reactively via events.
# AGENT_EVENT_BUS_ENABLED=false
# Redis connection URL
# AGENT_EVENT_BUS_REDIS_URL=redis://localhost:6379/0
# Consumer XREADGROUP block timeout in milliseconds
# AGENT_EVENT_BUS_CONSUMER_POLL_INTERVAL_MS=100
# Maximum delivery attempts before dead-lettering
# AGENT_EVENT_BUS_MAX_RETRIES=3
# Dead-letter stream name
# AGENT_EVENT_BUS_DEAD_LETTER_STREAM=stream:dead_letter
# Seconds before an unacknowledged message is considered stuck
# AGENT_EVENT_BUS_ACK_TIMEOUT_SECONDS=300

# =============================================================================
# KNOWLEDGE GRAPH FRESHNESS (ADR-0042)
# =============================================================================
# Enable access tracking + freshness scoring (default: False).
# When False, memory.accessed events are suppressed at all publish points (no-op publish).
# When True, events are published from all query paths and consumed by cg:freshness.
# AGENT_FRESHNESS_ENABLED=false
# Decay half-life in days (entity loses half its freshness score every N days without access)
# AGENT_FRESHNESS_HALF_LIFE_DAYS=30.0
# Days since last access after which an entity is dormant and flagged for archival review
# AGENT_FRESHNESS_COLD_THRESHOLD_DAYS=180.0
# Alpha coefficient in frequency boost: boost = min(1 + α × ln(1 + count), max_boost)
# AGENT_FRESHNESS_FREQUENCY_BOOST_ALPHA=0.1
# Maximum frequency boost multiplier
# AGENT_FRESHNESS_FREQUENCY_BOOST_MAX=1.5
# cg:freshness consumer accumulates events for this many seconds before a batch Neo4j write
# AGENT_FRESHNESS_CONSUMER_BATCH_WINDOW_SECONDS=5.0
# cg:freshness consumer flushes early when this many events accumulate in the window
# AGENT_FRESHNESS_CONSUMER_BATCH_MAX_EVENTS=50
# Cron expression for the weekly staleness-review brainstem job
# AGENT_FRESHNESS_REVIEW_SCHEDULE_CRON=0 3 * * 0
# Captain's Log proposals when dormant counts reach these thresholds
# AGENT_FRESHNESS_DORMANT_ENTITY_PROPOSAL_THRESHOLD=10
# AGENT_FRESHNESS_DORMANT_RELATIONSHIP_PROPOSAL_THRESHOLD=10
# Never-accessed entities older than this (days) are counted as extraction-noise signal
# AGENT_FRESHNESS_NEVER_ACCESSED_NOISE_DAYS=30.0
# Weight for freshness signal in relevance scoring (active only when freshness_enabled=True)
# AGENT_FRESHNESS_RELEVANCE_WEIGHT=0.15
# Must be true to run `uv run agent memory freshness-backfill` without --dry-run
# AGENT_FRESHNESS_BACKFILL_CONFIRM=false
#
# Operator flow (does not modify last_accessed_at or access_count):
#   uv run agent memory freshness-backfill --dry-run
#   AGENT_FRESHNESS_BACKFILL_CONFIRM=true uv run agent memory freshness-backfill
# Optional: --batch-size 100 (default; max 500 per CLI)

# =============================================================================
# PROACTIVE MEMORY (ADR-0039, FRE-174–176)
# =============================================================================
# Feature flag: when true, non–MEMORY_RECALL intents call suggest_relevant().
# Application default is false; set to true in `.env` to enable proactive memory locally.
# AGENT_PROACTIVE_MEMORY_ENABLED=false
#
# Optional tuning (defaults match PROACTIVE_MEMORY_DESIGN.md); all use AGENT_ prefix:
# AGENT_PROACTIVE_MEMORY_W_EMBEDDING=0.45
# AGENT_PROACTIVE_MEMORY_W_ENTITY=0.25
# AGENT_PROACTIVE_MEMORY_W_RECENCY=0.20
# AGENT_PROACTIVE_MEMORY_W_TOPIC=0.10
# AGENT_PROACTIVE_MEMORY_RECENCY_HALF_LIFE_DAYS=30.0
# AGENT_PROACTIVE_MEMORY_MIN_SCORE=0.3
# AGENT_PROACTIVE_MEMORY_MAX_TOKENS=500
# AGENT_PROACTIVE_MEMORY_MAX_CANDIDATES=10
# AGENT_PROACTIVE_MEMORY_MAX_INJECTED_ITEMS=5
# AGENT_PROACTIVE_MEMORY_DIMINISHING_SCORE_FLOOR=0.35
# AGENT_PROACTIVE_MEMORY_DIMINISHING_SCORE_GAP=0.15
# AGENT_PROACTIVE_MEMORY_VECTOR_TOP_K=20

# =============================================================================
# TEST / EVALUATION GATES
# =============================================================================
# Safety gates that prevent AI agents from accidentally firing live LLM calls.
# These must be set EXPLICITLY — they are never set by default.
#
# Required to run 'make test-integration' (fires 3-10 real LLM calls, ~5-15 min):
# PERSONAL_AGENT_INTEGRATION=1
#
# Required to run the eval harness 'make eval' (fires 100+ LLM calls, ~60-90 min):
# PERSONAL_AGENT_EVAL=1
