*.code-workspace

# Logs
telemetry/archive/
telemetry/logs/
*.log
*.jsonl

# Captain's Log entries (runtime artifacts, not source code)
telemetry/captains_log/**/*.json
# Captain's Log ES backfill checkpoint (FRE-30)
telemetry/captains_log/es_backfill_checkpoint.json

# Linear feedback loop (ADR-0040) — local history and poller state
telemetry/feedback_history/
telemetry/feedback_poller_state.json

# FRE-407 per-turn rating audit logs (runtime NDJSON — must never be committed)
telemetry/user_feedback/

# FRE-380 daily soak measurement outputs (regeneratable; ephemeral)
telemetry/soak/

# Evaluation harness per-run results (regeneratable from re-runs)
telemetry/evaluation/evaluation_report*.md
telemetry/evaluation/evaluation_results*.md
telemetry/evaluation/evaluation_results*.json
# Note: EVALUATION_TOOLS_USAGE.md is documentation and should be tracked

# Category-level test runs (debugging artifacts, not evaluation baselines)
telemetry/evaluation/EVAL-cat-*/

# Short-lived harness iteration dirs (regeneratable; keep named EVAL-NN-* baselines tracked)
telemetry/evaluation/EVAL-harness-iter*/

# Agent self-diagnosis evaluation runs — entire run directories (regeneratable)
telemetry/evaluation/EVAL-agent-self-diagnosis/*/

# Skill routing evaluation runs — entire run directories (regeneratable)
telemetry/evaluation/EVAL-skill-routing-*/

# Single-prompt retest runs (debugging artifacts from eval iteration — not baselines)
telemetry/evaluation/EVAL-primitive-tools/retest-*/

# Memory integration probe outputs — regeneratable; may contain turn-text excerpts
scripts/research/*/output/

# Empty or incomplete run directories
telemetry/evaluation/EVAL-primitive-tools/run-2026-04-27-1716/

# Superseded interim G1/G3 runs from 2026-04-28 — canonical results are
