.qodo
.playwright-mcp/
.worktrees/

.DS_Store

.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Testing & type checking cache
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.hypothesis/

# Coverage reports
.coverage
.coverage.*
htmlcov/
cover/

# Distribution / packaging
*.egg-info/
**/*.egg-info/
dist/
build/
*.egg

# IDE
*.code-workspace

# Logs
telemetry/archive/
telemetry/logs/
*.log
*.jsonl

# Captain's Log entries (runtime artifacts, not source code)
telemetry/captains_log/**/*.json
# Captain's Log ES backfill checkpoint (FRE-30)
telemetry/captains_log/es_backfill_checkpoint.json

# Linear feedback loop (ADR-0040) — local history and poller state
telemetry/feedback_history/
telemetry/feedback_poller_state.json

# Evaluation harness per-run results (regeneratable from re-runs)
telemetry/evaluation/evaluation_report*.md
telemetry/evaluation/evaluation_results*.md
telemetry/evaluation/evaluation_results*.json
# Note: EVALUATION_TOOLS_USAGE.md is documentation and should be tracked

# Category-level test runs (debugging artifacts, not evaluation baselines)
telemetry/evaluation/EVAL-cat-*/

# Short-lived harness iteration dirs (regeneratable; keep named EVAL-NN-* baselines tracked)
telemetry/evaluation/EVAL-harness-iter*/

# Evaluation research results ARE tracked — they back architectural decisions
# EVAL-NN-*/ directories (named baselines) are committed

# IDE files (additional)
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables (secrets, local configuration)
# Per ADR-0007: Unified Configuration Management
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test
# Note: .env.example is tracked as a template

# Experiment results (environment-specific, regeneratable)
experiments/*/results/

current_session

# Claude Code
.claude/worktrees/
.claude/todos/
.claude/.cache/
.claude/settings.json

# SearXNG generated files (ADR-0034)
docker/searxng/uwsgi.ini
docker/searxng/settings.yml.new

# Local git worktrees (`git worktree add .worktrees/...`) — not source
.worktrees/

# Terraform
infrastructure/terraform/terraform.tfvars

# Models
models/embedding/*
models/reranker/*

# Claude Code planning session artifacts (generated by /plan command)
# Anchored to repo root with leading slash; docs/plans/ is tracked project documentation
/plans/

# MCP gateway secrets (runtime credentials; see docker/mcp/mcp-secrets.env.example)
mcp-secrets.env
docker/mcp/mcp-secrets.env

# VPS/cloud env override (canonical secrets live in .env; this is a safety net)
.env.cloud
