# Dockerfile for Seshat API Gateway
#
# Cloud deployment image for the Knowledge Layer gateway.
# Exposes Knowledge API and Observation API over FastAPI/HTTPS.
#
# NOTE: This Dockerfile depends on personal_agent.gateway.app:create_gateway_app
# which is created by FRE-206. Once that task is complete, this will build
# and run the gateway service.
#
# Usage:
#   docker build -f Dockerfile.gateway -t seshat-gateway:latest .
#   docker run -p 9001:9001 seshat-gateway:latest

FROM python:3.12-slim

# FRE-278: install diagnostic tools referenced by skill docs and bash auto-approve list.
# procps (ps, top, free, vmstat, uptime), curl, jq, iproute2 (ss), net-tools (netstat).
# FRE-315: nodejs + chromium + fonts for @mermaid-js/mermaid-cli (diagram syntax validation).
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      procps \
      curl \
      jq \
      iproute2 \
      net-tools \
      sysstat \
      lsof \
      redis-tools \
      postgresql-client \
      nodejs \
      npm \
      chromium \
      fonts-liberation \
      libnss3 \
      libgbm1 \
      libxss1 \
      libasound2 \
    && rm -rf /var/lib/apt/lists/*

# FRE-315: mermaid-cli for diagram syntax validation. PUPPETEER_SKIP_CHROMIUM_DOWNLOAD prevents
# mmdc from downloading its own Chromium at install/run time; we use the apt-installed one above.
# Chromium running as root inside the container requires --no-sandbox — passed via a puppeteer
# config file, wired through a wrapper that shadows the global mmdc binary so the skill doc
# doesn't have to remember the flag.
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
RUN npm install -g --no-audit --no-fund @mermaid-js/mermaid-cli@^11 && \
    npm cache clean --force && \
    printf '{"args":["--no-sandbox","--disable-setuid-sandbox","--disable-dev-shm-usage"]}' \
      > /etc/mermaid-puppeteer.json && \
    mv /usr/local/bin/mmdc /usr/local/bin/mmdc.real && \
    printf '#!/bin/sh\nexec /usr/local/bin/mmdc.real -p /etc/mermaid-puppeteer.json "$@"\n' \
      > /usr/local/bin/mmdc && \
    chmod +x /usr/local/bin/mmdc

WORKDIR /app

# Docker CLI — needed to launch docker/mcp-gateway via mounted Docker socket (cloud MCP)
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker

# Install uv for fast, reliable dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy project dependencies and lock file
COPY pyproject.toml uv.lock ./

# Copy source code
COPY src/ src/
COPY config/ config/
COPY docs/skills/ docs/skills/
COPY docker/mcp/ docker/mcp/
RUN chmod +x docker/mcp/run-gateway.sh

# Install dependencies (production-only, no dev dependencies)
RUN uv sync --frozen --no-dev

HEALTHCHECK --interval=10s --timeout=5s --retries=5 --start-period=30s \
  CMD curl -fsS http://localhost:9001/health || exit 1

# Expose API port
EXPOSE 9001

# Run the full Seshat service app (orchestrator, memory, brainstem, AG-UI endpoints).
# ADR-0044/FRE-207: switched from thin gateway to full service app so the
# cloud profile can dispatch to LiteLLM via the profile-aware LLM factory.
CMD ["uv", "run", "uvicorn", "personal_agent.service.app:app", \
     "--host", "0.0.0.0", "--port", "9001"]
