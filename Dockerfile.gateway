# Dockerfile for Seshat API Gateway
#
# Cloud deployment image for the Knowledge Layer gateway.
# Exposes Knowledge API and Observation API over FastAPI/HTTPS.
#
# NOTE: This Dockerfile depends on personal_agent.gateway.app:create_gateway_app
# which is created by FRE-206. Once that task is complete, this will build
# and run the gateway service.
#
# Usage:
#   docker build -f Dockerfile.gateway -t seshat-gateway:latest .
#   docker run -p 9001:9001 seshat-gateway:latest

FROM python:3.12-slim

WORKDIR /app

# Install uv for fast, reliable dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy project dependencies and lock file
COPY pyproject.toml uv.lock ./

# Copy source code
COPY src/ src/
COPY config/ config/

# Install dependencies (production-only, no dev dependencies)
RUN uv sync --frozen --no-dev

# Health check (python instead of curl — slim image has no curl)
HEALTHCHECK --interval=10s --timeout=5s --retries=5 --start-period=15s \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:9001/api/v1/health')" || exit 1

# Expose API port
EXPOSE 9001

# Run the Seshat API Gateway factory function
# This creates the FastAPI app and runs it on 0.0.0.0:9001
#
# The factory function is defined in personal_agent/gateway/app.py
# and handles initialization of all Knowledge Layer connections.
CMD ["uv", "run", "uvicorn", "personal_agent.gateway.app:create_gateway_app", \
     "--factory", "--host", "0.0.0.0", "--port", "9001"]
