# Caddyfile for Cloud Simulation
#
# Routes:
#   /api/*             → seshat-gateway:9001  (REST API)
#   /chat, /chat/stream, /stream/* → seshat-gateway:9001  (AG-UI endpoints)
#   /docs, /openapi.json, /redoc → seshat-gateway:9001 (Swagger)
#   /*                 → seshat-pwa:3000      (Next.js PWA)
#
# Two site blocks share the same routing — HTTPS for SSH tunnel access,
# plain HTTP for WARP private network access (172.25.0.10).

{
	local_certs
	admin 0.0.0.0:2019
}

# Shared routing — gateway handles API paths, PWA handles everything else
(routing) {
	@backend path /api/* /chat /chat/stream /stream/* /docs /docs/* /openapi.json /redoc
	handle @backend {
		reverse_proxy seshat-gateway:9001 {
			header_up X-Forwarded-For {http.request.header.X-Forwarded-For}
			header_up X-Forwarded-Proto {http.request.proto}
			header_up X-Forwarded-Host {http.request.header.Host}
			transport http {
				dial_timeout 30s
				response_header_timeout 60s
			}
		}
	}
	handle {
		reverse_proxy seshat-pwa:3000
	}
	log {
		output stdout
		format json
	}
	handle_errors {
		@4xx expression `{http.error.status_code} >= 400 && {http.error.status_code} < 500`
		@5xx expression `{http.error.status_code} >= 500`
		respond @4xx "{http.error.status_code} {http.error.status_text}" {http.error.status_code}
		respond @5xx "Internal Server Error" 500
	}
}

# HTTPS — SSH tunnel dev access (curl -k https://localhost/...)
localhost {
	import routing
}

# HTTP — WARP private network access (phone → 172.25.0.10 via Cloudflare tunnel)
http://172.25.0.10 {
	import routing
}

# Cloudflare Tunnel — user-facing PWA + same-origin API
# Traffic arrives from cloudflared with Host: agent.frenchforet.com.
# Uses the shared routing snippet: /api/* → seshat-gateway:9001, /* → seshat-pwa:3000.
# :80 port suffix disables Caddy auto-HTTPS (http:// prefix alone is insufficient with local_certs).
agent.frenchforet.com:80 {
	import routing
}

# Cloudflare Tunnel — external agent API access
# All paths route directly to the gateway.
# TLS is terminated at the Cloudflare edge; traffic arrives here as plain HTTP.
# :80 port suffix disables Caddy auto-HTTPS.
api.frenchforet.com:80 {
	reverse_proxy seshat-gateway:9001 {
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {http.request.header.Host}
		transport http {
			dial_timeout 30s
			response_header_timeout 60s
		}
	}
	log {
		output stdout
		format json
	}
	handle_errors {
		@4xx expression `{http.error.status_code} >= 400 && {http.error.status_code} < 500`
		@5xx expression `{http.error.status_code} >= 500`
		respond @4xx "{http.error.status_code} {http.error.status_text}" {http.error.status_code}
		respond @5xx "Internal Server Error" 500
	}
}
