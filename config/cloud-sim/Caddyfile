# Caddyfile for Cloud Simulation
#
# Routes:
#   /api/*             → seshat-gateway:9001  (REST API)
#   /chat, /stream/*   → seshat-gateway:9001  (AG-UI endpoints)
#   /docs, /openapi.json, /redoc → seshat-gateway:9001 (Swagger)
#   /*                 → seshat-pwa:3000      (Next.js PWA)
#
# Two site blocks share the same routing — HTTPS for SSH tunnel access,
# plain HTTP for WARP private network access (172.25.0.10).

{
	local_certs
	admin 0.0.0.0:2019
}

# Shared routing — gateway handles API paths, PWA handles everything else
(routing) {
	@backend path /api/* /chat /stream/* /docs /docs/* /openapi.json /redoc
	handle @backend {
		reverse_proxy seshat-gateway:9001 {
			header_up X-Forwarded-For {http.request.header.X-Forwarded-For}
			header_up X-Forwarded-Proto {http.request.proto}
			header_up X-Forwarded-Host {http.request.header.Host}
			transport http {
				dial_timeout 30s
				response_header_timeout 60s
			}
		}
	}
	handle {
		reverse_proxy seshat-pwa:3000
	}
	log {
		output stdout
		format json
	}
	handle_errors {
		@4xx expression `{http.error.status_code} >= 400 && {http.error.status_code} < 500`
		@5xx expression `{http.error.status_code} >= 500`
		respond @4xx "{http.error.status_code} {http.error.status_text}" {http.error.status_code}
		respond @5xx "Internal Server Error" 500
	}
}

# HTTPS — SSH tunnel dev access (curl -k https://localhost/...)
localhost {
	import routing
}

# HTTP — WARP private network access (phone → 172.25.0.10 via Cloudflare tunnel)
http://172.25.0.10 {
	import routing
}
