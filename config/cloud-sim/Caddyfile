# Caddyfile for Cloud Simulation
#
# Reverse proxy configuration for the Seshat API Gateway.
# Provides TLS termination, rate limiting, and request routing.
#
# For local development/simulation:
# - Self-signed certificates generated automatically
# - Accessible at https://localhost:443
#
# For cloud VPS deployment:
# - Replace 'localhost' with your domain name
# - Let's Encrypt certificates provisioned automatically
# - Add rate limiting and auth directives as needed

{
	# Use self-signed certificates for local cloud simulation
	local_certs
}

# Main API endpoint
localhost {
	# Reverse proxy to Seshat API Gateway running on port 9001
	reverse_proxy seshat-gateway:9001 {
		# Preserve the original request headers
		header_up X-Forwarded-For {http.request.header.X-Forwarded-For}
		header_up X-Forwarded-Proto {http.request.proto}
		header_up X-Forwarded-Host {http.request.header.Host}

		# Timeout for long-running requests (e.g., knowledge graph queries)
		transport http {
			dial_timeout 30s
			response_header_timeout 30s
		}
	}

	# Enable access logs (optional, for debugging)
	log {
		output stdout
		format json
	}

	# Graceful error handling
	handle_errors {
		@4xx expression `{http.error.status_code} >= 400 && {http.error.status_code} < 500`
		@5xx expression `{http.error.status_code} >= 500`

		respond @4xx "{http.error.status_code} {http.error.status_text}" {http.error.status_code}
		respond @5xx "Internal Server Error" 500
	}
}
