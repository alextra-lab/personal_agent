{
  "index_patterns": ["agent-logs-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.codec": "best_compression",
      "index.refresh_interval": "5s",
      "index.mapping.total_fields.limit": 300,
      "index.mapping.total_fields.ignore_dynamic_beyond_limit": true
    },
    "mappings": {
      "dynamic": true,
      "dynamic_templates": [
        {
          "ms_fields_as_float": {
            "match_pattern": "regex",
            "match": "^(.*_ms|.*_seconds|.*_latency|.*_duration|.*_offset)$",
            "match_mapping_type": "*",
            "mapping": { "type": "float" }
          }
        },
        {
          "numeric_ratios_as_float": {
            "match_pattern": "regex",
            "match": "^(.*_ratio|.*_rate|.*_score|.*_pct|.*_percent|.*_cost_usd|confidence|.*_confidence)$",
            "match_mapping_type": "*",
            "mapping": { "type": "float" }
          }
        },
        {
          "ids_keyword": {
            "match": "*_id",
            "match_mapping_type": "string",
            "mapping": { "type": "keyword" }
          }
        },
        {
          "enums_keyword": {
            "match_pattern": "regex",
            "match": "^(.*_type|.*_name|.*_role|.*_status|.*_decision|.*_strategy|.*_mode|.*_phase|.*_action|.*_kind|.*_state)$",
            "match_mapping_type": "string",
            "mapping": { "type": "keyword" }
          }
        },
        {
          "free_text": {
            "match_pattern": "regex",
            "match": "^(.*_message|.*_content|.*_description|reason|hint|stderr|stdout|raw_.*|.*_text|.*_prompt|content|content_value|.*_preview|.*_excerpt|summary)$",
            "match_mapping_type": "string",
            "mapping": { "type": "text" }
          }
        },
        {
          "default_string_keyword": {
            "match_mapping_type": "string",
            "mapping": {
              "type": "keyword",
              "ignore_above": 1024
            }
          }
        }
      ],
      "properties": {
        "@timestamp":         { "type": "date" },
        "event":              { "type": "keyword" },
        "event_type":         { "type": "keyword" },
        "arguments": {
          "type": "object",
          "dynamic": false,
          "properties": {
            "name":     { "type": "keyword" },
            "title":    { "type": "keyword" },
            "trace_id": { "type": "keyword" }
          }
        },
        "context_messages":   { "properties": { "role": { "type": "keyword" } } },
        "messages_preview":   { "properties": { "role": { "type": "keyword" } } },
        "phases_summary": {
          "properties": {
            "llm_inference":  { "properties": { "duration_ms": { "type": "float" } } },
            "other":          { "properties": { "duration_ms": { "type": "float" } } },
            "persistence":    { "properties": { "duration_ms": { "type": "float" } } },
            "setup":          { "properties": { "duration_ms": { "type": "float" } } },
            "synthesis":      { "properties": { "duration_ms": { "type": "float" } } },
            "tool_execution": { "properties": { "duration_ms": { "type": "float" } } }
          }
        },
        "attempt_number":     { "type": "long" },
        "cpu_load":           { "type": "float" },
        "memory_used":        { "type": "float" },
        "from_state":         { "type": "keyword" },
        "role":               { "type": "keyword" },
        "target_agent":       { "type": "keyword" },
        "title":              { "type": "keyword" },
        "trimmed":            { "type": "boolean" },
        "trace_id":           { "type": "keyword" },
        "span_id":            { "type": "keyword" },
        "session_id":         { "type": "keyword" },
        "component":          { "type": "keyword" },
        "level":              { "type": "keyword" },
        "message":            { "type": "text" },
        "user_message":       { "type": "text" },
        "error": {
          "type": "text",
          "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
        },
        "task_type":           { "type": "keyword" },
        "complexity":          { "type": "keyword" },
        "confidence":          { "type": "float" },
        "signals":             { "type": "keyword" },
        "mode":                { "type": "keyword" },
        "expansion_permitted": { "type": "boolean" },
        "expansion_budget":    { "type": "integer" },
        "strategy":            { "type": "keyword" },
        "reason":              { "type": "keyword", "ignore_above": 1024 },
        "denial_reason":       { "type": "keyword", "ignore_above": 8192 },
        "calibration_threshold": { "type": "float" },
        "governance_threshold":  { "type": "float" },
        "threshold":             { "type": "float" },
        "message_count":       { "type": "integer" },
        "token_count":         { "type": "integer" },
        "estimated_tokens":    { "type": "integer" },
        "total_tokens":        { "type": "long" },
        "max_tokens":          { "type": "integer" },
        "budget_trimmed":      { "type": "boolean" },
        "overflow_action":     { "type": "keyword" },
        "has_memory":          { "type": "boolean" },
        "candidate_set_size":  { "type": "integer" },
        "result_count":        { "type": "integer" },
        "empty_result":        { "type": "boolean" },
        "top_vector_score":    { "type": "float" },
        "median_vector_score": { "type": "float" },
        "vector_entity_count": { "type": "integer" },
        "recency_span_seconds":{ "type": "float" },
        "recall_latency_ms":   { "type": "float" },
        "recalled_token_count":{ "type": "integer" },
        "similarity_floor":    { "type": "float" },
        "relevance_bounded_enabled": { "type": "boolean" },
        "has_tools":           { "type": "boolean" },
        "degraded_stages":     { "type": "keyword" },
        "sub_agent_count":     { "type": "integer" },
        "max_concurrent":      { "type": "integer" },
        "total":               { "type": "integer" },
        "successes":           { "type": "integer" },
        "failures":            { "type": "integer" },
        "promoted":            { "type": "integer" },
        "skipped":             { "type": "integer" },
        "errors":              { "type": "integer" },
        "entity_name":         { "type": "keyword" },
        "entity_type":         { "type": "keyword" },
        "tool_name":           { "type": "keyword" },
        "tool_count":          { "type": "integer" },
        "success":             { "type": "boolean" },
        "model_role":          { "type": "keyword" },
        "model":               { "type": "keyword" },
        "endpoint":            { "type": "keyword" },
        "api_type":            { "type": "keyword" },
        "input_tokens":        { "type": "long" },
        "output_tokens":       { "type": "long" },
        "cache_read_tokens":   { "type": "long" },
        "cache_creation_input_tokens": { "type": "long" },
        "cost_usd":            { "type": "double" },
        "amount_usd":             { "type": "double" },
        "actual_cost_usd":        { "type": "double" },
        "reserved_usd":           { "type": "double" },
        "delta_usd":              { "type": "double" },
        "reservation_amount_usd": { "type": "double" },
        "running_total":          { "type": "double" },
        "cap_usd":                { "type": "double" },
        "utilization_ratio":      { "type": "double" },
        "window_start":           { "type": "date" },
        "session_cost_usd":       { "type": "double" },
        "session_context_tokens": { "type": "long" },
        "compaction_count":       { "type": "integer" },
        "cache_reset_count":      { "type": "integer" },
        "quality_alert_count":    { "type": "integer" },
        "quality_alert": {
          "type": "object",
          "properties": {
            "severity":     { "type": "keyword" },
            "phases_fired": { "type": "integer" }
          }
        },
        "prompt_callsite":           { "type": "keyword" },
        "prompt_component_ids":      { "type": "keyword" },
        "prompt_static_prefix_hash": { "type": "keyword" },
        "prompt_dynamic_hash":       { "type": "keyword" },
        "prompt_injected":           { "type": "boolean" },
        "latency_ms":          { "type": "long" },
        "duration_ms":         { "type": "float" },
        "total_duration_ms":   { "type": "float" },
        "offset_ms":           { "type": "float" },
        "response_time_ms":    { "type": "float" },
        "total_steps":         { "type": "integer" },
        "sequence":            { "type": "integer" },
        "phase":               { "type": "keyword" },
        "name":                { "type": "keyword" },
        "tags":                { "type": "keyword" },
        "metrics": {
          "type": "object",
          "properties": {
            "cpu_percent":    { "type": "float" },
            "memory_percent": { "type": "float" },
            "gpu_percent":    { "type": "float" },
            "disk_percent":   { "type": "float" }
          }
        },
        "phases": {
          "type": "nested",
          "properties": {
            "phase":       { "type": "keyword" },
            "duration_ms": { "type": "float" },
            "offset_ms":   { "type": "float" },
            "start_time":  { "type": "keyword" },
            "end_time":    { "type": "keyword" },
            "description": { "type": "text" }
          }
        },
        "envelope_ok":           { "type": "boolean" },
        "csp_present":           { "type": "boolean" },
        "mime_ok":               { "type": "boolean" },
        "nosniff_ok":            { "type": "boolean" },
        "missing_directives":    { "type": "keyword" },
        "mismatched_directives": { "type": "keyword" },
        "unexpected_directives": { "type": "keyword" },
        "envelope_failures":     { "type": "keyword" },
        "served_mime":           { "type": "keyword" },
        "probe_status":          { "type": "keyword" },
        "csp_header":            { "type": "keyword", "ignore_above": 2048 },
        "http_status":           { "type": "integer" },
        "probe_duration_ms":     { "type": "integer" },
        "external_script_count": { "type": "long" },
        "script_reach_allowed":  { "type": "long" },
        "script_reach_blocked":  { "type": "long" }
      }
    }
  },
  "_meta": {
    "description": "agent-logs-* telemetry catch-all. ADR-0090 Guarded-dynamic discipline (dynamic:true + dynamic_templates covering strings/numerics + explicit props for every known numeric/long-text/join field), bounded by FRE-544: index.mapping.total_fields.limit=300 with ignore_dynamic_beyond_limit=true so over-cap dynamic leaves are skipped to _source (never drop the doc). Numeric coverage (FRE-567, ADR-0090 D2): ms_fields_as_float (*_ms/_seconds/_latency/_duration/_offset) + numeric_ratios_as_float (*_ratio/_rate/_score/_pct/_percent/_cost_usd/confidence/*_confidence) pin a new unlisted float-quantity field first-seen as 0 to float, defeating the float->long trap; integer counters (*_count/iteration/max_iterations) are intentionally left to long. ADR-0092 turn_status session fields (FRE-571, ADR-0090 D6): session_cost_usd (double, money — matches the *_usd convention, defeats float->long), session_context_tokens (long), compaction_count/cache_reset_count/quality_alert_count (integer), quality_alert (object: severity keyword + phases_fired integer) are pinned explicitly so they are never silently coerced if they reach this catch-all (today they flow only to Postgres session_events + live WS, not ES — pre-positioned per Guarded-dynamic). The arguments.* tool-call subtree is dynamic:false (kept name/title/trace_id) to stop the fastest-growing sprawl source. All dashboard-referenced fields are explicit so the cap can never skip a panel field. FRE-534/536 trap fixes preserved. Drift enforcement: FRE-540 reconciliation checker (ADR-0090 D5). Existing 768-field indices age out via the 30d ILM (ilm-policy.json); the bound applies to new daily indices.",
    "managed_by": "scripts/setup-elasticsearch.sh",
    "total_fields_limit": 300
  }
}
