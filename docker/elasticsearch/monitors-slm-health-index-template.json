{
  "index_patterns": ["agent-monitors-slm-health-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.codec": "best_compression",
      "index.refresh_interval": "10s",
      "index.lifecycle.name": "agent-monitors-slm-health-policy"
    },
    "mappings": {
      "dynamic": true,
      "dynamic_templates": [
        {
          "ms_fields_as_float": {
            "match_pattern": "regex",
            "match": "^(.*_ms|.*_seconds|.*_latency|.*_duration|.*_offset)$",
            "match_mapping_type": "*",
            "mapping": { "type": "float" }
          }
        },
        {
          "ids_keyword": {
            "match": "*_id",
            "match_mapping_type": "string",
            "mapping": { "type": "keyword" }
          }
        },
        {
          "default_string_keyword": {
            "match_mapping_type": "string",
            "mapping": { "type": "keyword", "ignore_above": 1024 }
          }
        }
      ],
      "properties": {
        "status":          { "type": "keyword" },
        "reachable":       { "type": "boolean" },
        "model_loaded":    { "type": "boolean" },
        "gpu_util_pct":    { "type": "float" },
        "vram_used_mb":    { "type": "float" },
        "vram_total_mb":   { "type": "float" },
        "queue_depth":     { "type": "integer" },
        "latency_ema_ms":  { "type": "float" },
        "model_id":        { "type": "keyword" },
        "probe_latency_ms":{ "type": "float" },
        "probed_at":       { "type": "date" },
        "trace_id":        { "type": "keyword" },
        "error":           { "type": "text" },
        "kind":            { "type": "keyword" }
      }
    }
  },
  "_meta": {
    "description": "SLM health probe snapshots (ADR-0083 / FRE-399). One doc per probe, daily index agent-monitors-slm-health-YYYY.MM.DD. Mapping covers the full 14-field SlmHealthSnapshot model (FRE-534/A2): the live data only ever populated 7 fields because the rest arrive null and never triggered a dynamic mapping. trace_id is keyword (was text under ES-default) so exact-term joins to slm-requests/agent-logs work — the join-key fix that the joinability story depends on.",
    "managed_by": "scripts/setup-elasticsearch.sh"
  }
}
