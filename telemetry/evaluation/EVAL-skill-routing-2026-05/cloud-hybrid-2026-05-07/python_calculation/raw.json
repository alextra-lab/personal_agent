          "script": "\nimport math\n\ndata = [120, 340, 89, 2100, 450, 210, 178, 990, 67, 3400, 230, 560, 44, 780, 155]\nn = len(data)\n\n# Step 1: Sort the data\nsorted_data = sorted(data)\nprint(f\"Step 1 \u2014 Sorted data ({n} values):\")\nprint(sorted_data)\n\n# Step 2: Compute rank index using the standard formula\n# rank = (p/100) * (n - 1)  [0-based index]\np = 95\nrank = (p / 100) * (n - 1)\nprint(f\"\\nStep 2 \u2014 Compute rank index (0-based):\")\nprint(f\"  rank = ({p}/100) \u00d7 ({n} - 1) = {p/100} \u00d7 {n-1} = {rank}\")\n\n# Step 3: Identify floor and ceiling indices\nlower_idx = math.floor(rank)\nupper_idx = math.ceil(rank)\nfraction = rank - lower_idx\nprint(f\"\\nStep 3 \u2014 Floor index: {lower_idx}, Ceiling index: {upper_idx}, Fraction: {fraction}\")\nprint(f\"  sorted_data[{lower_idx}] = {sorted_data[lower_idx]}\")\nprint(f\"  sorted_data[{upper_idx}] = {sorted_data[upper_idx]}\")\n\n# Step 4: Linear interpolation\np95 = sorted_data[lower_idx] + fraction * (sorted_data[upper_idx] - sorted_data[lower_idx])\nprint(f\"\\nStep 4 \u2014 Linear interpolation:\")\nprint(f\"  P95 = {sorted_data[lower_idx]} + {fraction} \u00d7 ({sorted_data[upper_idx]} - {sorted_data[lower_idx]})\")\nprint(f\"  P95 = {sorted_data[lower_idx]} + {fraction} \u00d7 {sorted_data[upper_idx] - sorted_data[lower_idx]}\")\nprint(f\"  P95 = {p95} ms\")\n\n# Cross-check with numpy\nimport numpy as np\nnp_p95 = np.percentile(data, 95)\nprint(f\"\\nCross-check (numpy.percentile, linear method): {np_p95} ms\")\n"
        }
      },
