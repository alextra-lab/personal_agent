          "script": "\nimport numpy as np\n\ndata = [120, 340, 89, 2100, 450, 210, 178, 990, 67, 3400, 230, 560, 44, 780, 155]\nn = len(data)\n\n# Step 1: Sort the data\nsorted_data = sorted(data)\nprint(f\"Step 1 \u2014 Sorted data ({n} values):\")\nprint(sorted_data)\n\n# Step 2: Compute rank/index using the standard linear interpolation method\n#         (same as numpy's default: linear interpolation, equivalent to Excel PERCENTILE.INC)\np = 95\npercentile_value = np.percentile(sorted_data, p, method='linear')\n\n# Step 3: Show the index calculation manually\n#         index L = (p/100) * (n - 1)\nL = (p / 100) * (n - 1)\nlower_idx = int(L)\nupper_idx = lower_idx + 1\nfraction = L - lower_idx\n\nlower_val = sorted_data[lower_idx]\nupper_val = sorted_data[upper_idx]\nmanual = lower_val + fraction * (upper_val - lower_val)\n\nprint(f\"\\nStep 2 \u2014 Rank index calculation:\")\nprint(f\"  L = (p/100) \u00d7 (n\u22121) = ({p}/100) \u00d7 ({n}\u22121) = 0.95 \u00d7 {n-1} = {L}\")\nprint(f\"  Lower index  = {lower_idx}  \u2192 value = {lower_val} ms\")\nprint(f\"  Upper index  = {upper_idx}  \u2192 value = {upper_val} ms\")\nprint(f\"  Fractional part = {fraction}\")\n\nprint(f\"\\nStep 3 \u2014 Linear interpolation:\")\nprint(f\"  P95 = {lower_val} + {fraction} \u00d7 ({upper_val} \u2212 {lower_val})\")\nprint(f\"      = {lower_val} + {fraction} \u00d7 {upper_val - lower_val}\")\nprint(f\"      = {lower_val} + {fraction * (upper_val - lower_val)}\")\nprint(f\"      = {manual:.2f} ms\")\n\nprint(f\"\\n\u2705 numpy verification: {percentile_value:.2f} ms\")\n"
        }
