          "script": "import math\n\ndata = [120, 340, 89, 2100, 450, 210, 178, 990, 67, 3400, 230, 560, 44, 780, 155]\n\n# Step 1: Sort the data\nsorted_data = sorted(data)\nn = len(sorted_data)\n\nprint(f\"Sorted data ({n} values): {sorted_data}\")\n\n# Step 2: Calculate the rank index using the standard interpolation method\n# Method: rank = (P/100) * (n - 1), 0-indexed\np = 95\nrank = (p / 100) * (n - 1)\nprint(f\"\\nP = {p}%\")\nprint(f\"n = {n}\")\nprint(f\"Rank index (0-based) = ({p}/100) \u00d7 ({n}-1) = {rank}\")\n\n# Step 3: Linear interpolation between the two surrounding values\nlower_idx = int(math.floor(rank))\nupper_idx = int(math.ceil(rank))\nfraction = rank - lower_idx\n\nprint(f\"\\nLower index: {lower_idx}, value = {sorted_data[lower_idx]}\")\nprint(f\"Upper index: {upper_idx}, value = {sorted_data[upper_idx]}\")\nprint(f\"Fraction: {fraction}\")\n\np95 = sorted_data[lower_idx] + fraction * (sorted_data[upper_idx] - sorted_data[lower_idx])\n\nprint(f\"\\nP95 = {sorted_data[lower_idx]} + {fraction} \u00d7 ({sorted_data[upper_idx]} - {sorted_data[lower_idx]})\")\nprint(f\"P95 = {sorted_data[lower_idx]} + {fraction} \u00d7 {sorted_data[upper_idx] - sorted_data[lower_idx]}\")\nprint(f\"P95 = {p95} ms\")\n"
        }
