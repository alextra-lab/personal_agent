          "script": "import math\n\ndata = [120, 340, 89, 2100, 450, 210, 178, 990, 67, 3400, 230, 560, 44, 780, 155]\nn = len(data)\np = 95\n\n# Step 1: Sort the data\nsorted_data = sorted(data)\nprint(f\"Sorted data ({n} values): {sorted_data}\")\nprint()\n\n# Step 2: Calculate the rank (1-based index) using the common method\n# rank = p/100 * (n - 1) + 1  (1-based)\n# or equivalently: index = p/100 * (n - 1)  (0-based)\nindex = (p / 100) * (n - 1)\nprint(f\"Percentile: {p}%\")\nprint(f\"Number of values (n): {n}\")\nprint(f\"0-based index: ({p}/100) \u00d7 ({n} - 1) = {p/100} \u00d7 {n-1} = {index}\")\nprint()\n\n# Step 3: Linear interpolation\nlower_idx = int(math.floor(index))\nupper_idx = int(math.ceil(index))\nfraction = index - lower_idx\n\nlower_val = sorted_data[lower_idx]\nupper_val = sorted_data[upper_idx]\n\nresult = lower_val + fraction * (upper_val - lower_val)\n\nprint(f\"Lower index: {lower_idx} \u2192 value = {lower_val}\")\nprint(f\"Upper index: {upper_idx} \u2192 value = {upper_val}\")\nprint(f\"Fraction: {fraction}\")\nprint(f\"Interpolation: {lower_val} + {fraction} \u00d7 ({upper_val} - {lower_val})\")\nprint(f\"             = {lower_val} + {fraction} \u00d7 {upper_val - lower_val}\")\nprint(f\"             = {lower_val} + {fraction * (upper_val - lower_val):.1f}\")\nprint(f\"             = {result}\")\nprint()\nprint(f\"P95 = {result} ms\")\n"
        }
      },
